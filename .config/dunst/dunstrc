[global]
    # Width of the notification window (min of 100, max of 300).
    width = (100, 300)

    # Offset from the origin.
    offset = 20x20

    # Maximum number of notifications.
    notification_limit = 20

    # Corner radius.
    corner_radius = 5

    # Remove the window frame.
    frame_width = 0

    # Spacing between lines.
    line_height = 4

    # Gap between notications.
    gap_size = 8

    # Font.
    font = Cartograph CF 8

    # Support for HTML markup.
    markup = full

    # The default format of the message.
    format = "<i>%a: %s</i>\n%b"

    # Truncate long lines at the end.
    ellipsize = end

    # Recursive icon lookup to avoid having to define all lookup paths.
    enable_recursive_icon_lookup = true
    icon_theme = Win10Sur

    # Keep icons small.
    min_icon_size = 16
    max_icon_size = 32

    # Remove the progress bar border.
    progress_bar_frame_width = 0

# Notification rules.
[urgency_low]
    background = "#31344F90"
    foreground = "#FFFFFF"
    timeout = 5

[urgency_normal]
    background = "#31344F90"
    foreground = "#FFFFFF"
    timeout = 5

[urgency_critical]
    background = "#E1129970"
    foreground = "#FFFFFF"
    timeout = 10

[backlight]
    appname = Backlight
    format = "<b>%a</b>\n%b"
    foreground = "#363636"
    background = "#A9ABAC90"
    highlight = "#363636"
    default_icon = display-brightness-medium-symbolic
    timeout = 1

# vim: ft=cfg
