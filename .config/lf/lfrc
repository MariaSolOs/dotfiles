# Show hidden files.
set hidden

# Show the size of files.
set info size

# Show the number of items inside directories.
set dircounts

# Icons!
set icons

# Use a 4-space tab.
set tabstop 4

# Remove the username and hostname from the prompt.
set promptfmt "\033[34;1m%d\033[0m\033[1m%f\033[0m"

# Use bat as a previewer.
# TODO: Handle images and non-previewable files.
set previewer ~/.config/lf/preview.sh
map i $~/.config/lf/preview.sh $f

# Remove the underline from right panes and underline parent directories.
set cursorpreviewfmt ""
set cursorparentfmt "\033[4m"

# Synchronous opening.
cmd open ${{
    case $(file --mime-type -Lb $f) in
        text/*) nvim $fx;;
        image/*) chromium --new-window $fx;;
        *) for f in $fx; do xdg-open $f > /dev/null 2> /dev/null & done;;
    esac
}}

# Remove mappings I don't use.
map <up>
map <down>
map <left>
map <right>
map <pgup>
map <pgdn>
map <home>
map <end>
map ?

# Copy/add to the cut buffer.
map c cut

# Clear the files in the copy/cut buffer.
map <esc> clear

# Remove the default move after toggling.
map <space> toggle

# Backtick for going to a bookmark.
map ` mark-load

# File creation.
map o push %touch<space>
cmd mkdir %mkdir -p "$@"
map O push %mkdir<space>

# Trash.
cmd trash %trash-put $fx
map d trash
