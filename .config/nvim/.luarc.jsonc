{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "workspace": {
    "library": [
      // Runtime and builtin libraries.
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      // Extra configuration helpers.
      "lua/float_term.lua",
      "lua/icons.lua",
      "lua/lsp.lua",
      // Include some plugins for API completion.
      "$XDG_DATA_HOME/nvim/lazy/LuaSnip/lua",
      "$XDG_DATA_HOME/nvim/lazy/alpha-nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/bufferline.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/Comment.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/copilot.lua/lua",
      "$XDG_DATA_HOME/nvim/lazy/crates.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/dracula.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/dressing.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/dropbar.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/flash.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/fzf-lua/lua",
      "$XDG_DATA_HOME/nvim/lazy/lazy.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/lsp-format.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.ai/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.files/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.hipatterns/lua",
      "$XDG_DATA_HOME/nvim/lazy/noice.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-autopairs/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-cmp/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-dap-ui/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-dap/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-ufo/lua",
      "$XDG_DATA_HOME/nvim/lazy/rust-tools.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/vim-illuminate/lua",
      "$XDG_DATA_HOME/nvim/lazy/which-key.nvim/lua"
    ]
  }
}
